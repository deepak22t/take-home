{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "types": ["node", "jest", "react", "react-dom"],
    "typeRoots": ["./node_modules/@types"],
    "baseUrl": ".",
    "paths": {
      "react-redux": [
        "./node_modules/react-redux/dist/react-redux.d.ts"
      ],
      "@testing-library/react": [
        "./node_modules/@testing-library/react/types/index.d.ts"
      ],
      "@testing-library/user-event": [
        "./node_modules/@testing-library/user-event/dist/types/index.d.ts"
      ],
      "@testing-library/jest-dom": [
        "./node_modules/@testing-library/jest-dom/types/index.d.ts"
      ],
      "@/*": [
        "./*"
      ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/*.d.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
